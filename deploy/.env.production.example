APP_NAME=PioDeploy
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://piodeploy.com

# Force https URLs behind the TLS proxy
ASSET_URL=https://piodeploy.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=piodeploy_platform
DB_USERNAME=piodeploy
DB_PASSWORD=change-this-strong-password

# Sessions/cache/queue on Linux prod — Redis is ideal; database is fine to start.
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis   # switch on once Redis is installed
# REDIS_HOST=127.0.0.1

# Real mail so notifications reach people (example: any SMTP provider)
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@piodeploy.com"
MAIL_FROM_NAME="PioDeploy"

# Online payments (paste your own Stripe keys when ready — test first)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Agent tuning (also editable in Admin -> Settings once live)
PIODEPLOY_ONLINE_THRESHOLD=300
PIODEPLOY_OFFLINE_ALERT_MINUTES=60
